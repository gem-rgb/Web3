# Core environment
RMS_ENVIRONMENT=development
LOG_LEVEL=info
RMS_SECRETS_DIR=

# Platform services
RMS_POSTGRES_HOST=localhost
RMS_POSTGRES_PORT=5432
RMS_POSTGRES_USER=rms_user
RMS_POSTGRES_PASSWORD=rms_password
RMS_POSTGRES_DB=rms_db
RMS_REDIS_HOST=localhost
RMS_REDIS_PORT=6379
RMS_KAFKA_BROKERS=localhost:9092
RMS_NATS_URL=nats://localhost:4222

# Security
RMS_AUTH_SECRET=dev-auth-secret
RMS_AUTH_ISSUER=rms-auth
RMS_AUTH_AUDIENCE=rms-platform
RMS_AUTH_TTL=15m
RMS_AUTH_CLIENTS=trading-platform:dev-secret:institutional:trader,allocator;ops-console:dev-secret:operations:admin

# Service endpoints
RMS_HTTP_PORT=8080
RMS_AUTH_HTTP_PORT=8081
RMS_AUTH_GRPC_PORT=50061
RMS_GATEWAY_RATE_LIMIT=200
RMS_GATEWAY_RATE_WINDOW=1m
RMS_ORDER_INGESTION_ADDR=localhost:50062
RMS_RULE_ENGINE_ADDR=localhost:50064
RMS_RISK_EVAL_ADDR=localhost:50063
RMS_MARKET_DATA_ADDR=localhost:50054
RMS_POSITION_TRACKING_ADDR=localhost:50056
RMS_EXPOSURE_ADDR=localhost:50055
RMS_MARGIN_ADDR=localhost:50057
RMS_ALERTING_ADDR=localhost:50052
RMS_AUDIT_ADDR=localhost:50053
RMS_DECISION_STORE_PATH=data/risk-decisions.jsonl
RMS_RISK_WORKERS=8
RMS_RISK_QUEUE=512

# Observability
RMS_OTEL_COLLECTOR_ENDPOINT=localhost:4317
RMS_PROMETHEUS_ENDPOINT=localhost:9090
RMS_JAEGER_ENDPOINT=localhost:14250
